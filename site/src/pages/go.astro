---
/**
 * /go — Google Ads bridge page.
 *
 * Captures the gclid from the inbound ad click, stores it in localStorage
 * (same origin as /setting-up which reads it back after the user installs
 * the extension), and immediately redirects to the Chrome Web Store
 * listing. The user sees this page for ~50ms.
 *
 * Why a bridge page rather than redirecting straight to CWS:
 *   - The Chrome Web Store is a third-party domain we can't instrument.
 *   - Google Ads auto-tagging only attaches gclid to URLs we control.
 *   - localStorage on promptory.chat persists across the install round-trip
 *     so /setting-up can recover the gclid and ping our backend.
 */
const CWS_URL = 'https://chromewebstore.google.com/detail/hbaodafglfcggljhdefilahgcpipcckg';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Promptory — Loading…</title>
  <link rel="icon" href="/favicon.png" />
  <style>
    html, body { margin: 0; padding: 0; height: 100%; font-family: -apple-system, BlinkMacSystemFont, 'Inter', sans-serif; background: #fff; color: #0f0f0f; }
    .wrap { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%; gap: 16px; }
    .logo { width: 56px; height: 56px; border-radius: 14px; background: #e11d48; display: flex; align-items: center; justify-content: center; color: #fff; font-size: 28px; font-weight: 900; }
    .text { color: #555; font-size: 15px; }
    .spinner { width: 18px; height: 18px; border: 2px solid #e11d48; border-top-color: transparent; border-radius: 50%; animation: spin 0.8s linear infinite; }
    @keyframes spin { to { transform: rotate(360deg); } }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="logo">P</div>
    <div class="text">Redirecting to Chrome Web Store…</div>
    <div class="spinner"></div>
    <noscript>
      <p style="margin-top:24px"><a href={CWS_URL}>Continue to Chrome Web Store →</a></p>
    </noscript>
  </div>
  <script is:inline define:vars={{ CWS_URL }}>
    (function () {
      try {
        const url = new URL(window.location.href);
        const gclid = url.searchParams.get('gclid');
        if (gclid && /^[A-Za-z0-9_-]{16,200}$/.test(gclid)) {
          localStorage.setItem(
            'promptory_gclid',
            JSON.stringify({ value: gclid, capturedAt: Date.now() }),
          );
        }
      } catch (e) {
        // localStorage blocked / unavailable — proceed without attribution
      }
      // Use replace so the bridge page doesn't end up in browser history
      window.location.replace(CWS_URL);
    })();
  </script>
</body>
</html>
