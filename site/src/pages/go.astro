---
/**
 * /go — Google Ads bridge page.
 *
 * Captures the gclid from the inbound ad click into localStorage on
 * page load, then waits for the user to click "Add to <Browser>".
 * Same origin as /setting-up which reads the gclid back after install.
 *
 * Click-through bridge (vs. auto-redirect) on purpose:
 *   - Shows users they're on the right brand before leaving
 *   - Avoids pop-up blockers / scammy auto-redirect feel
 *   - Higher-intent click → better install rate downstream
 *
 * The CTA is rewritten client-side based on the detected browser so a
 * Firefox user lands on AMO and an Edge user lands on the Edge store.
 * Initial render is the Chrome variant (largest audience, safe default).
 */
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Promptory — Add to Chrome</title>
  <link rel="icon" href="/favicon.png" />
  <style>
    :root {
      --brand: #e11d48;
      --brand-d: #be123c;
      --text: #0f0f0f;
      --muted: #555;
    }
    * { box-sizing: border-box; }
    html, body { margin: 0; padding: 0; height: 100%; font-family: -apple-system, BlinkMacSystemFont, 'Inter', sans-serif; background: #fff; color: var(--text); }
    .wrap {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-height: 100%;
      padding: 32px 20px;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .wrap::before {
      content: '';
      position: absolute;
      top: -200px; right: -200px;
      width: 600px; height: 600px;
      background: radial-gradient(ellipse at center, #ffe4ea 0%, rgba(255,255,255,0) 65%);
      pointer-events: none;
      z-index: 0;
    }
    .inner { position: relative; z-index: 1; max-width: 480px; }
    .logo {
      width: 64px; height: 64px;
      border-radius: 16px;
      background: var(--brand);
      display: inline-flex; align-items: center; justify-content: center;
      color: #fff; font-size: 32px; font-weight: 900;
      margin-bottom: 24px;
      box-shadow: 0 8px 24px rgba(225, 29, 72, 0.25);
    }
    h1 {
      font-size: 32px;
      font-weight: 900;
      letter-spacing: -1px;
      line-height: 1.15;
      margin: 0 0 12px;
    }
    h1 em { color: var(--brand); font-style: normal; }
    p.lead {
      font-size: 17px;
      color: var(--muted);
      line-height: 1.55;
      margin: 0 0 32px;
    }
    .cta {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      background: var(--brand);
      color: #fff;
      padding: 14px 28px;
      border-radius: 12px;
      text-decoration: none;
      font-size: 16px;
      font-weight: 700;
      box-shadow: 0 6px 20px rgba(225, 29, 72, 0.3);
      transition: transform 0.15s, box-shadow 0.15s, background 0.15s;
    }
    .cta:hover {
      background: var(--brand-d);
      transform: translateY(-1px);
      box-shadow: 0 8px 28px rgba(225, 29, 72, 0.35);
    }
    .meta {
      margin-top: 20px;
      font-size: 13px;
      color: #888;
    }
    .browser-icon {
      width: 18px; height: 18px;
      border-radius: 50%;
      display: inline-block;
      position: relative;
    }
    .browser-icon[data-browser="chrome"] {
      background: conic-gradient(from 0deg, #4285f4, #ea4335 33%, #fbbc04 66%, #34a853);
    }
    .browser-icon[data-browser="chrome"]::after {
      content: ''; position: absolute; inset: 4px;
      background: #fff; border-radius: 50%;
    }
    .browser-icon[data-browser="edge"] {
      background: conic-gradient(from 200deg, #0078d4, #00bcf2 40%, #50e6ff 70%, #0078d4);
    }
    .browser-icon[data-browser="edge"]::after {
      content: ''; position: absolute; inset: 5px;
      background: #fff; border-radius: 50%;
    }
    .browser-icon[data-browser="firefox"] {
      background: radial-gradient(circle at 60% 60%, #ffcb05 0%, #ff7139 35%, #e62b1e 70%, #b71c1c 100%);
    }
  </style>
</head>
<body>
  <main class="wrap">
    <div class="inner">
      <div class="logo">P</div>
      <h1>Add Promptory<br/>to <em id="browser-name">Chrome</em></h1>
      <p class="lead">Auto-saves every prompt you send to ChatGPT, Claude, Gemini and more — so you never lose a great one.</p>

      <a class="cta" href="https://chromewebstore.google.com/detail/hbaodafglfcggljhdefilahgcpipcckg" id="cta">
        <span class="browser-icon" data-browser="chrome" id="cta-icon"></span>
        <span id="cta-label">Add to Chrome — it's free</span>
      </a>

      <div class="meta">No account · Works in 30 seconds</div>
    </div>
  </main>

  <script is:inline>
    /**
     * Marketplace registry. Initial render uses the 'chrome' variant;
     * detectBrowser() picks the right key and we rewrite the CTA + heading.
     */
    var MARKETPLACES = {
      chrome: {
        url: 'https://chromewebstore.google.com/detail/hbaodafglfcggljhdefilahgcpipcckg',
        label: "Add to Chrome — it's free",
        name: 'Chrome',
      },
      edge: {
        url: 'https://microsoftedge.microsoft.com/addons/detail/promptory-ai-prompt-dir/glbjaogmndihnahlnkjgdgigichmkbhp',
        label: "Add to Edge — it's free",
        name: 'Edge',
      },
      firefox: {
        url: 'https://addons.mozilla.org/en-US/firefox/addon/promptory/',
        label: "Add to Firefox — it's free",
        name: 'Firefox',
      },
    };

    // Order matters: Edge UA contains both "Edg/" and "Chrome/", so test
    // Edge first or Edge users get routed to CWS. Firefox is exclusive.
    // Brave/Opera/Arc fall through to 'chrome' (all install from CWS).
    function detectBrowser() {
      var ua = navigator.userAgent || '';
      if (/Firefox\//.test(ua)) return 'firefox';
      if (/Edg\//.test(ua)) return 'edge';
      return 'chrome';
    }

    (function () {
      // Capture gclid for /setting-up to fire an offline ad conversion.
      try {
        var url = new URL(window.location.href);
        var gclid = url.searchParams.get('gclid');
        if (gclid && /^[A-Za-z0-9_-]{16,200}$/.test(gclid)) {
          localStorage.setItem(
            'promptory_gclid',
            JSON.stringify({ value: gclid, capturedAt: Date.now() }),
          );
        }
      } catch (e) {
        // ignore
      }

      // Rewrite CTA + heading for the detected browser.
      try {
        var key = detectBrowser();
        var mp = MARKETPLACES[key] || MARKETPLACES.chrome;
        var cta = document.getElementById('cta');
        var icon = document.getElementById('cta-icon');
        var label = document.getElementById('cta-label');
        var name = document.getElementById('browser-name');
        if (cta) cta.setAttribute('href', mp.url);
        if (icon) icon.setAttribute('data-browser', key);
        if (label) label.textContent = mp.label;
        if (name) name.textContent = mp.name;
      } catch (e) {
        // leave the Chrome default in place
      }
    })();
  </script>
</body>
</html>
