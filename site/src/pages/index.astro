---
import Layout from '../layouts/Layout.astro';

const CWS_URL = 'https://chromewebstore.google.com/detail/YOUR_EXTENSION_ID';
---

<Layout title="Promptory — Your AI Prompt Library">

  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <div class="hero-badge"><span></span> Free Chrome Extension</div>
      <h1>Your AI prompt library,<br><em>always one click away.</em></h1>
      <p class="hero-sub">
        Automatically saves every prompt you send to ChatGPT, Claude, Gemini and more.
        Search, tag, and reuse your best ideas instantly.
      </p>
      <div class="hero-cta">
        <a href={CWS_URL} target="_blank" class="btn-cta">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
            <circle cx="9" cy="9" r="8.5" stroke="white" stroke-opacity=".5"/>
            <circle cx="9" cy="9" r="3.5" fill="white"/>
          </svg>
          Add to Chrome — it's free
        </a>
        <a href="#how-it-works" class="btn-ghost">
          See how it works
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
            <path d="M3 7h8M8 4l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
      <div class="hero-img">
        <div class="dash"><img src="/assets/dashboard.png" alt="Promptory dashboard" loading="eager" /></div>
        <div class="panel"><img src="/assets/sidepanel.png" alt="Promptory side panel" loading="eager" /></div>
      </div>
    </div>
  </section>

  <!-- Platforms -->
  <div class="platforms">
    <div class="container">
      <p>Works with your favorite AI tools</p>
      <div class="platform-list">
        <span class="chip"><span class="dot" style="background:#10a37f"></span>ChatGPT</span>
        <span class="chip"><span class="dot" style="background:#f97316"></span>Claude</span>
        <span class="chip"><span class="dot" style="background:#4285f4"></span>Gemini</span>
        <span class="chip"><span class="dot" style="background:#22b5ac"></span>Perplexity</span>
        <span class="chip"><span class="dot" style="background:#111111"></span>Grok</span>
        <span class="chip"><span class="dot" style="background:#0078d4"></span>Copilot</span>
      </div>
    </div>
  </div>

  <!-- How it works -->
  <section id="how-it-works" class="section-white">
    <div class="container">
      <div class="section-label">How it works</div>
      <h2>Three steps. Zero effort.</h2>
      <p class="section-sub">Works silently in the background — no copy-pasting, no manual saving.</p>
      <div class="steps">
        <div class="step">
          <div class="step-num">1</div>
          <h3>Install &amp; forget</h3>
          <p>Add Promptory to Chrome. It immediately starts watching your AI conversations.</p>
        </div>
        <div class="step">
          <div class="step-num">2</div>
          <h3>Prompts auto-save</h3>
          <p>Every prompt you send — and the AI's response — is saved on your device. Nothing leaves your browser.</p>
        </div>
        <div class="step">
          <div class="step-num">3</div>
          <h3>Search &amp; reuse</h3>
          <p>Open the side panel, search by keyword, filter by platform, and paste any prompt back in one click.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section id="features" class="section-soft">
    <div class="container">
      <div class="section-label">Features</div>
      <h2>Everything you need,<br>nothing you don't.</h2>
      <div class="features-grid">
        {[
          { icon: '⚡', title: 'Auto-capture', body: 'Prompts are saved automatically as you type — no buttons, no workflow changes.' },
          { icon: '🔍', title: 'Instant search', body: 'Full-text search across all your saved prompts and responses. Find anything fast.' },
          { icon: '🏷️', title: 'Smart tags', body: 'Auto-tagged by platform. Add your own tags to organize by project or topic.' },
          { icon: '📋', title: 'One-click paste', body: 'Hit Paste in the side panel to inject any saved prompt directly into the active AI tool.' },
          { icon: '🔒', title: '100% local & private', body: 'All data lives in your browser. Nothing is sent to our servers without your consent.' },
          { icon: '📤', title: 'Export anytime', body: 'Export your entire library as JSON or CSV with one click. Your data, your way.' },
        ].map(f => (
          <div class="feature-card">
            <div class="feature-icon">{f.icon}</div>
            <h3>{f.title}</h3>
            <p>{f.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA band -->
  <div class="cta-band">
    <div class="container">
      <h2>Stop losing your best prompts.</h2>
      <p>Join thousands of AI users who never repeat themselves.</p>
      <a href={CWS_URL} target="_blank" class="btn-white">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
          <circle cx="9" cy="9" r="8.5" stroke="#e11d48" stroke-opacity=".3"/>
          <circle cx="9" cy="9" r="3.5" fill="#e11d48"/>
        </svg>
        Add to Chrome — it's free
      </a>
    </div>
  </div>

</Layout>

<style>
  /* ── Hero ── */
  .hero {
    padding: 80px 24px 96px;
    background: linear-gradient(160deg, #fff 0%, #fff1f2 60%, #fff 100%);
    text-align: center;
  }
  .hero-badge {
    display: inline-flex; align-items: center; gap: 7px;
    background: #fff1f2; border: 1px solid #fecdd3;
    border-radius: 20px; padding: 5px 14px;
    font-size: 12.5px; font-weight: 600; color: var(--brand);
    margin-bottom: 28px;
  }
  .hero-badge span { width: 7px; height: 7px; border-radius: 50%; background: var(--brand); display: inline-block; }
  h1 { font-size: clamp(36px, 6vw, 68px); font-weight: 800; letter-spacing: -2px; line-height: 1.08; max-width: 820px; margin: 0 auto 20px; }
  h1 em { font-style: normal; color: var(--brand); }
  .hero-sub { font-size: clamp(16px, 2.5vw, 20px); color: var(--muted); max-width: 560px; margin: 0 auto 40px; line-height: 1.6; }
  .hero-cta { display: flex; align-items: center; justify-content: center; gap: 14px; flex-wrap: wrap; }
  .btn-cta {
    background: var(--brand); color: #fff;
    padding: 13px 24px; border-radius: 9px;
    font-size: 15px; font-weight: 600;
    display: inline-flex; align-items: center; gap: 8px;
    transition: background .15s, transform .1s;
  }
  .btn-cta:hover { background: var(--brand-d); transform: translateY(-1px); }
  .btn-ghost { font-size: 14px; font-weight: 500; color: var(--muted); display: inline-flex; align-items: center; gap: 6px; }
  .btn-ghost:hover { color: var(--text); }
  .hero-img { max-width: 960px; margin: 64px auto 0; position: relative; }
  .dash { border-radius: 16px; overflow: hidden; box-shadow: 0 4px 6px rgba(0,0,0,0.04), 0 20px 60px rgba(0,0,0,0.12); }
  .dash img { width: 100%; display: block; }
  .panel { position: absolute; bottom: -24px; left: -24px; width: 220px; border-radius: 14px; overflow: hidden; box-shadow: 0 4px 6px rgba(0,0,0,0.06), 0 16px 48px rgba(0,0,0,0.16); transform: rotate(-2deg); }
  .panel img { width: 100%; display: block; }

  /* ── Platforms ── */
  .platforms { padding: 48px 24px; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); background: var(--bg-soft); }
  .platforms p { text-align: center; font-size: 13px; color: #aaa; font-weight: 500; letter-spacing: 0.5px; text-transform: uppercase; margin-bottom: 24px; }
  .platform-list { display: flex; align-items: center; justify-content: center; gap: 12px; flex-wrap: wrap; }
  .chip { display: inline-flex; align-items: center; gap: 8px; border: 1.5px solid var(--border); border-radius: 24px; padding: 8px 16px; background: #fff; font-size: 13.5px; font-weight: 600; }
  .dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }

  /* ── How it works ── */
  .section-white { padding: 96px 24px; background: #fff; }
  .section-white h2, .section-soft h2 { font-size: clamp(28px, 4vw, 42px); font-weight: 800; letter-spacing: -1px; line-height: 1.15; margin-bottom: 16px; }
  .section-sub { font-size: 17px; color: var(--muted); max-width: 520px; }
  .steps { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 32px; margin-top: 56px; }
  .step { text-align: center; }
  .step-num { width: 48px; height: 48px; border-radius: 50%; background: var(--brand); color: #fff; font-size: 20px; font-weight: 800; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px; }
  .step h3 { font-size: 17px; font-weight: 700; margin-bottom: 8px; }
  .step p { font-size: 14px; color: var(--muted); line-height: 1.65; max-width: 280px; margin: 0 auto; }

  /* ── Features ── */
  .section-soft { padding: 96px 24px; background: var(--bg-soft); }
  .features-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 24px; margin-top: 56px; }
  .feature-card { border: 1px solid var(--border); border-radius: var(--radius); padding: 28px; background: #fff; transition: box-shadow .2s, transform .2s; }
  .feature-card:hover { box-shadow: 0 8px 32px rgba(0,0,0,0.08); transform: translateY(-2px); }
  .feature-icon { width: 44px; height: 44px; border-radius: 11px; background: #fff1f2; display: flex; align-items: center; justify-content: center; margin-bottom: 16px; font-size: 22px; }
  .feature-card h3 { font-size: 16px; font-weight: 700; margin-bottom: 8px; }
  .feature-card p { font-size: 14px; color: var(--muted); line-height: 1.65; }

  /* ── CTA band ── */
  .cta-band { background: linear-gradient(135deg, var(--brand) 0%, var(--brand-d) 100%); padding: 80px 24px; text-align: center; color: #fff; }
  .cta-band h2 { font-size: clamp(24px, 4vw, 38px); font-weight: 800; letter-spacing: -1px; color: #fff; margin-bottom: 12px; }
  .cta-band p { color: rgba(255,255,255,0.8); font-size: 17px; margin-bottom: 36px; }
  .btn-white { background: #fff; color: var(--brand); padding: 13px 28px; border-radius: 10px; font-size: 15px; font-weight: 700; display: inline-flex; align-items: center; gap: 8px; box-shadow: 0 4px 20px rgba(0,0,0,0.15); transition: transform .15s; }
  .btn-white:hover { transform: translateY(-2px); }

  @media (max-width: 640px) {
    .panel { width: 140px; left: -8px; bottom: -16px; }
  }
</style>
