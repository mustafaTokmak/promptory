---
/**
 * /setting-up — minimal loading bridge.
 *
 * Opened by the extension's onInstalled handler immediately after install.
 * The Promptory content script (on promptory.chat) runs in this tab,
 * reads any gclid stored by /go, forwards it to the background worker
 * for the conversion ping, then asks the background worker to close
 * this tab and open the extension's dashboard instead.
 *
 * If the extension isn't installed (someone navigated here directly),
 * we just show the loading state and link to the Chrome Web Store
 * after a short delay.
 */
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Promptory — Setting up…</title>
  <link rel="icon" href="/favicon.png" />

  <!-- GA4 — page_view auto-fires from config; install_completed and
       conversion_* events fire from the inline script below. Same
       property as extension + /go for unified funnel reporting. -->
  <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-B9R8M4RJP6"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-B9R8M4RJP6');
  </script>

  <style>
    :root { --brand: #e11d48; }
    * { box-sizing: border-box; }
    html, body { margin: 0; padding: 0; height: 100%; font-family: -apple-system, BlinkMacSystemFont, 'Inter', sans-serif; background: #fff; color: #0f0f0f; }
    .wrap { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%; gap: 18px; padding: 24px; text-align: center; }
    .logo { width: 56px; height: 56px; border-radius: 14px; background: var(--brand); display: flex; align-items: center; justify-content: center; color: #fff; font-size: 28px; font-weight: 900; box-shadow: 0 6px 20px rgba(225,29,72,0.25); }
    .text { color: #555; font-size: 15px; }
    .spinner { width: 18px; height: 18px; border: 2px solid var(--brand); border-top-color: transparent; border-radius: 50%; animation: spin 0.8s linear infinite; }
    @keyframes spin { to { transform: rotate(360deg); } }
    .fallback { display: none; margin-top: 24px; }
    .fallback.show { display: block; }
    .fallback a { color: var(--brand); }
  </style>
</head>
<body>
  <main class="wrap">
    <div class="logo">P</div>
    <div class="text">Setting up Promptory…</div>
    <div class="spinner"></div>

    <div class="fallback" id="fallback">
      <p style="color:#888;font-size:13px">Doesn't look like Promptory is installed yet.</p>
      <a href="https://chromewebstore.google.com/detail/hbaodafglfcggljhdefilahgcpipcckg">
        Add Promptory to Chrome →
      </a>
    </div>
  </main>

  <script is:inline>
    // If 5 seconds pass without the content script taking over, the
    // extension probably isn't installed — surface a fallback link.
    setTimeout(() => {
      document.getElementById('fallback')?.classList.add('show');
    }, 5000);

    // ─── Page-side conversion fire (stopgap for v0.2.0) ──────────────────
    // The extension's content-script → background → API chain isn't
    // reporting reliably. We're firing the same POST directly from this
    // page until the extension flow is fixed. /setting-up is only ever
    // opened by the extension's onInstalled handler, and we additionally
    // gate on gclid presence — so this only fires for ad-attributed
    // installs, never random visitors.
    var CONVERSION_ENDPOINT = 'https://api.promptory.chat/v1/conversion';
    var REPORTED_FLAG_KEY = 'promptory_gclid_reported';
    var MAX_AGE_MS = 30 * 24 * 60 * 60 * 1000; // matches /go

    function readStoredGclid() {
      try {
        var raw = localStorage.getItem('promptory_gclid');
        if (!raw) return null;
        var parsed = JSON.parse(raw);
        if (!parsed || !parsed.value) return null;
        var age = Date.now() - (parsed.capturedAt || 0);
        if (age > MAX_AGE_MS) {
          localStorage.removeItem('promptory_gclid');
          return null;
        }
        return { gclid: parsed.value, capturedAt: parsed.capturedAt || Date.now() };
      } catch (e) {
        return null;
      }
    }

    /**
     * Fire the install conversion to api.promptory.chat/v1/conversion.
     *
     * Body shape (matches what the extension was sending — keep it identical
     * so backend dedup-by-gclid keeps working once the extension is fixed):
     *   { gclid, conversionTime: <ISO string>, capturedAt: <ms epoch> }
     *
     * Decisions to make:
     *   1. De-dup on the client: if a user reloads /setting-up, do we re-fire?
     *      Suggested: write REPORTED_FLAG_KEY to localStorage on success,
     *      skip the POST if it's already set. Backend should also dedup,
     *      but client-side avoids the wasted request.
     *   2. Error handling: log and move on (telemetry must never throw),
     *      do NOT block UI on this — the page's primary job is to swap to
     *      the dashboard, not to confirm conversion.
     *   3. Keep-alive: this tab may close fast once the extension takes
     *      over. Use `fetch(..., { keepalive: true })` so the request
     *      survives tab teardown.
     *
     * @param {{ gclid: string, capturedAt: number }} stored
     * @returns {Promise<void>}
     */
    function track(event, params) {
      // gtag() is defined synchronously by the loader snippet above, so it
      // is always callable here. dataLayer queues events until the GA4
      // script finishes loading.
      try {
        gtag('event', event, params || {});
      } catch (e) {
        // analytics never blocks the conversion path
      }
    }

    async function fireConversion(stored) {
      try {
        if (localStorage.getItem(REPORTED_FLAG_KEY) === stored.gclid) {
          track('conversion_skipped', { reason: 'already_reported' });
          return;
        }
        track('conversion_attempt');
        var res = await fetch(CONVERSION_ENDPOINT, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            gclid: stored.gclid,
            conversionTime: new Date().toISOString(),
            capturedAt: stored.capturedAt,
            source: 'page',
          }),
          keepalive: true,
        });
        if (res.ok) {
          var body = null;
          try { body = await res.json(); } catch (e) { /* ignore parse */ }
          track('conversion_success', { deduped: !!(body && body.deduped) });
          localStorage.setItem(REPORTED_FLAG_KEY, stored.gclid);
        } else {
          track('conversion_failed', { reason: 'http_' + res.status });
          console.warn('[Promptory] conversion API returned', res.status);
        }
      } catch (err) {
        track('conversion_failed', { reason: 'network' });
        console.warn('[Promptory] page-side conversion fire failed', err);
      }
    }

    (function () {
      var stored = readStoredGclid();
      track('install_completed', { from_ad: !!stored });
      if (!stored) return;
      fireConversion(stored);
    })();
  </script>
</body>
</html>
