---
/**
 * /setting-up — minimal loading bridge.
 *
 * Opened by the extension's onInstalled handler immediately after install.
 * The Promptory content script (on promptory.chat) runs in this tab,
 * reads any gclid stored by /go, forwards it to the background worker
 * for the conversion ping, then asks the background worker to close
 * this tab and open the extension's dashboard instead.
 *
 * If the extension isn't installed (someone navigated here directly),
 * we just show the loading state and link to the Chrome Web Store
 * after a short delay.
 */
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Promptory — Setting up…</title>
  <link rel="icon" href="/favicon.png" />
  <style>
    :root { --brand: #e11d48; }
    * { box-sizing: border-box; }
    html, body { margin: 0; padding: 0; height: 100%; font-family: -apple-system, BlinkMacSystemFont, 'Inter', sans-serif; background: #fff; color: #0f0f0f; }
    .wrap { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%; gap: 18px; padding: 24px; text-align: center; }
    .logo { width: 56px; height: 56px; border-radius: 14px; background: var(--brand); display: flex; align-items: center; justify-content: center; color: #fff; font-size: 28px; font-weight: 900; box-shadow: 0 6px 20px rgba(225,29,72,0.25); }
    .text { color: #555; font-size: 15px; }
    .spinner { width: 18px; height: 18px; border: 2px solid var(--brand); border-top-color: transparent; border-radius: 50%; animation: spin 0.8s linear infinite; }
    @keyframes spin { to { transform: rotate(360deg); } }
    .fallback { display: none; margin-top: 24px; }
    .fallback.show { display: block; }
    .fallback a { color: var(--brand); }
  </style>
</head>
<body>
  <main class="wrap">
    <div class="logo">P</div>
    <div class="text">Setting up Promptory…</div>
    <div class="spinner"></div>

    <div class="fallback" id="fallback">
      <p style="color:#888;font-size:13px">Doesn't look like Promptory is installed yet.</p>
      <a href="https://chromewebstore.google.com/detail/hbaodafglfcggljhdefilahgcpipcckg">
        Add Promptory to Chrome →
      </a>
    </div>
  </main>

  <script is:inline>
    // If 5 seconds pass without the content script taking over, the
    // extension probably isn't installed — surface a fallback link.
    setTimeout(() => {
      document.getElementById('fallback')?.classList.add('show');
    }, 5000);
  </script>
</body>
</html>
